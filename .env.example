# ==============================================================================
#                     MITSURU TOPUP HUB - ENVIRONMENT CONFIG (TEMPLATE)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION (Switchable DB Backend)
# ------------------------------------------------------------------------------
# Pilihan: 'supabase' atau 'mysql'
DB_PROVIDER=mysql

# A. Konfigurasi Database MySQL (Aktif jika DB_PROVIDER=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=freelance_topup

POSTGRES_URL="postgresql://postgres.[project_ref]:[password_db]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ------------------------------------------------------------------------------
# 2. SUPABASE SDK CREDENTIALS (Client/Server Connection)
# ------------------------------------------------------------------------------
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ------------------------------------------------------------------------------
# 3. DIGIFLAZZ CONFIGURATION (Top-Up Provider)
# ------------------------------------------------------------------------------
# A. Mode Produksi (Uang Asli - Transaksi Riil)
DIGIFLAZZ_USERNAME=your_production_username
DIGIFLAZZ_API_KEY=your_production_api_key
DIGIFLAZZ_MODE=production

# B. Mode Simulasi / Sandbox (Untuk testing/development)
# DIGIFLAZZ_USERNAME=your_sandbox_username
# DIGIFLAZZ_API_KEY=your_sandbox_api_key
# DIGIFLAZZ_MODE=simulation

# Webhook Secret & Keamanan
DIGIFLAZZ_WEBHOOK_SECRET=your_digiflazz_webhook_secret

# ------------------------------------------------------------------------------
# 4. SECURITY & AUTHENTICATION (Monolith Local JWT)
# ------------------------------------------------------------------------------
# Kunci rahasia untuk tanda tangan token JWT sesi local (MySQL)
JWT_SECRET=your_jwt_secret_token_here

# ------------------------------------------------------------------------------
# 5. OAUTH CREDENTIALS (Social Logins - Google & Discord)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id_here

# ------------------------------------------------------------------------------
# 6. APPLICATION CONFIGURATIONS
# ------------------------------------------------------------------------------
# Ganti dengan domain publik ketika website dirilis ke hosting
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# 7. MIDTRANS PAYMENT GATEWAY CONFIGURATION
# ------------------------------------------------------------------------------
# Kunci Server & Client Key Midtrans (Mode Sandbox / Production)
MIDTRANS_SERVER_KEY=your_midtrans_server_key_here
MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here

MIDTRANS_SANDBOX_SERVER_KEY=your_midtrans_sandbox_server_key_here
MIDTRANS_SANDBOX_CLIENT_KEY=your_midtrans_sandbox_client_key_here